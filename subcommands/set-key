#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/config"
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/common-functions"

cmd-agent-set-key() {
  declare desc="Set an API key (e.g. ANTHROPIC_API_KEY) in the plugin keys file"
  local cmd="agent:set-key"
  [[ "$1" == "$cmd" ]] && shift 1
  declare KEY="$1"
  shift 1
  declare VALUE="$*"

  [[ -z "$KEY" ]] && dokku_log_fail "Usage: dokku agent:set-key <KEY> <value>"
  agent_set_key "$KEY" "$VALUE"
}

cmd-agent-set-key "$@"
