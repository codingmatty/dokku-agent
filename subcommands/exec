#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/config"

: "${DOCKER_BIN:=docker}"

cmd-agent-exec() {
  declare desc="Run Docker Agent in headless mode (--exec)"
  declare cmd="agent:exec"
  [[ "$1" == "$cmd" ]] && shift 1

  agent_load_keys
  if ! command -v "$DOCKER_BIN" &>/dev/null; then
    dokku_log_fail "Docker not found. Dokku requires Docker to be installed."
  fi

  if ! "$DOCKER_BIN" agent run --help &>/dev/null; then
    dokku_log_fail "Docker Agent CLI not found. Run 'dokku agent:install' for instructions."
  fi

  if [[ $# -lt 2 ]]; then
    dokku_log_fail "Usage: dokku agent:exec <config> <message...>"
  fi

  local config="$1"
  shift
  exec "$DOCKER_BIN" agent run --exec "$config" "$@"
}

cmd-agent-exec "$@"
