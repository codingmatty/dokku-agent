#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"

: "${DOCKER_BIN:=docker}"

cmd-agent-run() {
  declare desc="Run Docker Agent (TUI or with messages)"
  declare cmd="agent:run"
  [[ "$1" == "$cmd" ]] && shift 1

  if ! command -v "$DOCKER_BIN" &>/dev/null; then
    dokku_log_fail "Docker not found. Dokku requires Docker to be installed."
  fi

  if ! "$DOCKER_BIN" agent run --help &>/dev/null; then
    dokku_log_fail "Docker Agent CLI not found. Run 'dokku agent:install' for instructions."
  fi

  exec "$DOCKER_BIN" agent run "$@"
}

cmd-agent-run "$@"
